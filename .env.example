# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=lunasol
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL="postgresql://postgres:postgres@db:5432/lunasol?schema=public"

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@lunasol.dev
PGADMIN_DEFAULT_PASSWORD=admin

# ── Clerk ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ── LiveKit (video consultations) ─────────────────────────────────────────────
# API key/secret sign room join tokens (NestJS) and authenticate the server.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=                # generate a long random secret (e.g. openssl rand -hex 32)
# Browser-facing WebSocket URL — reaches LiveKit through Nginx at /meet.
# dev: ws://localhost:81/meet   prod: wss://<your-domain>/meet
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:81/meet

# ── App ports (override if needed) ────────────────────────────────────────────
WEB_PORT=3000
API_PORT=3001
AI_PORT=8000
PGADMIN_PORT=5050

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://ai:8000
MODEL_PATH=/models/model.gguf
MOCK_MODE=true
N_GPU_LAYERS=-1
